# SAM 3 Inference Service Environment Variables
# Copy this file to .env and fill in your values

# HuggingFace Access Token (REQUIRED)
# Get your token from: https://huggingface.co/settings/tokens
# Request SAM 3 access at: https://huggingface.co/facebook/sam3
HF_TOKEN=your_huggingface_token_here

# Model Device
# Options: "cuda" or "cpu"
# Default: "cuda" (if CUDA is available)
MODEL_DEVICE=cuda

# Disable SAM 3 autocast (use float32) to fix "BFloat16 and bias type (float) should be the same" on RunPod/some GPUs
# Set to "true" if you see that RuntimeError
DISABLE_SAM3_AUTOCAST=false

# Video Download Settings
MAX_VIDEO_SIZE_MB=500
VIDEO_DOWNLOAD_TIMEOUT=120

# Inference Settings
# Default max frames when client omits max_frames (0 = no cap).
# 90 = 6–12 GB VRAM; 300 = A40/24GB+; 0 = process full video
DEFAULT_MAX_FRAMES=300
INFERENCE_TIMEOUT=300

# Server Configuration
HOST=0.0.0.0
PORT=8000
